GOOGLE_API_KEY=replace-with-your-gemini-api-key
ANALYZE_AGENT_MODEL=gemini-2.5-flash
ANALYZE_AGENT_LOG_LEVEL=INFO
VITE_ANALYZE_API_BASE_URL=http://localhost:8000
ANALYZE_API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ANALYZE_API_MAX_JOBS=100
ANALYZE_API_MAX_EVENTS_PER_JOB=200
ANALYZE_API_EVENT_POLL_SECONDS=0.05
ANALYZE_AGENT_MODEL_TIMEOUT_SECONDS=30
ANALYZE_AGENT_RETRIEVER_TIMEOUT_SECONDS=10
ANALYZE_AGENT_MAX_ATTEMPTS=2
ANALYZE_AGENT_SCHEMA_REPAIR_ATTEMPTS=1
