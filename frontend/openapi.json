      "UpdateJobRequest": {
        "additionalProperties": false,
        "properties": {
          "knowledge_base_scenario": {
            "$ref": "#/components/schemas/DemoKnowledgeScenario",
            "default": "empty"
          },
          "requirement_id": {
            "format": "uuid",
            "title": "Requirement Id",
            "type": "string"
          },
          "search_feedback": {
            "items": {
              "$ref": "#/components/schemas/SearchFeedback"
            },
            "title": "Search Feedback",
            "type": "array"
          },
          "supplemental_information": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Supplemental Information"
          }
        },
        "required": [
          "requirement_id"
        ],
        "title": "UpdateJobRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkflowStage": {
        "enum": [
          "validating_input",
          "loading_revision",
          "updating_requirement",
          "analyzing_requirement",
          "searching_knowledge_base",
          "reconstructing_mappings",
          "calculating_confidence",
          "persisting_revision",
          "completed",
          "failed"
        ],
        "title": "WorkflowStage",
        "type": "string"
      }
    }
  },
